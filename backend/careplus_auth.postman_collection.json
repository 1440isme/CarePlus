  "item": [
    {
      "name": "Auth - Register & Email Verification",
      "item": [
        {
          "name": "Register Patient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyen Van A\",\n  \"email\": \"{{email}}\",\n  \"phone\": \"0901234567\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "description": "Register a patient account. OTP is stored in Redis at otp:email-verify:{email}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Register success envelope is valid', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data).to.have.property('user');",
                  "  pm.expect(json.data).to.have.property('verification');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Register Patient - Duplicate Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyen Van A\",\n  \"email\": \"{{email}}\",\n  \"phone\": \"0901234567\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "description": "Run after a successful register to confirm EMAIL_ALREADY_EXISTS."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 409', function () {",
                  "  pm.response.to.have.status(409);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Duplicate email error code is correct', function () {",
                  "  pm.expect(json.success).to.eql(false);",
                  "  pm.expect(json.error.code).to.eql('EMAIL_ALREADY_EXISTS');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Resend Verification OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/resend-verification-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "resend-verification-otp"
              ]
            },
            "description": "Request a new verification OTP. Redis key stays otp:email-verify:{email} with a refreshed TTL."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Resend OTP response is valid', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.verification.required).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Resend Verification OTP - Rate Limit",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/resend-verification-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "resend-verification-otp"
              ]
            },
            "description": "Run this request repeatedly more than 3 times in 5 minutes to confirm rate limiting."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Rate limit status is 429 when threshold is exceeded', function () {",
                  "  pm.expect([200, 429]).to.include(pm.response.code);",
                  "  if (pm.response.code === 429) {",
                  "    pm.expect(json.success).to.eql(false);",
                  "    pm.expect(['TOO_MANY_OTP_REQUESTS', 'TOO_MANY_REQUESTS']).to.include(json.error.code);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
