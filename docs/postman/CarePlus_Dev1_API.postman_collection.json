{
  "info": {
    "_postman_id": "f4bcdb62-b6de-4d01-b8fb-f44517c2e111",
    "name": "CarePlus Dev1 API",
    "description": "Dev 1 scoped collection for Auth, User, Patient Profiles, Clinic Settings, and Specialties. No real secrets, OTPs, or tokens are stored here.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyen Van A\",\n  \"email\": \"patient@example.com\",\n  \"phone\": \"0901234567\",\n  \"password\": \"Password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Create a patient account and trigger email verification OTP."
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/verify-email",
            "description": "Verify email by OTP. Fill {{otp}} manually from the safe test source."
          }
        },
        {
          "name": "Resend Verification OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\"\n}"
            },
            "url": "{{baseUrl}}/auth/resend-verification-otp",
            "description": "Actual route in code. Not /auth/resend-otp."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\",\n  \"password\": \"Password123\",\n  \"rememberMe\": false\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Stores accessToken into collection variables. Refresh token stays in httpOnly cookie."
          }
        },
        {
          "name": "Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{baseUrl}}/auth/refresh",
            "description": "Uses refreshToken httpOnly cookie. Send raw JSON {} because validator expects a strict empty body."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{baseUrl}}/auth/logout",
            "description": "Uses refreshToken httpOnly cookie. Send raw JSON {} because validator expects a strict empty body."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\"\n}"
            },
            "url": "{{baseUrl}}/auth/forgot-password",
            "description": "Generate password reset flow. Do not store real reset tokens in this collection."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\",\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"{{newPassword}}\",\n  \"confirmPassword\": \"{{newPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/reset-password",
            "description": "Current backend flow uses email + token, not OTP."
          }
        }
      ]
    },
